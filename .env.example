# ─── Authentication: pick ONE of the two modes below ───

# Mode A (recommended): Service Account JSON
# Stringify the full JSON key file downloaded from GCP.
# The service account email must be invited as Admin on the target GTM accounts.
# No token expiration — cleanest for external client audits.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Mode B (fallback): OAuth2 refresh-token flow
# Generate refresh_token via https://developers.google.com/oauthplayground
# Scopes required:
#   https://www.googleapis.com/auth/tagmanager.manage.accounts
#   https://www.googleapis.com/auth/tagmanager.edit.containers
#   https://www.googleapis.com/auth/tagmanager.edit.containerversions
#   https://www.googleapis.com/auth/tagmanager.publish
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ─── Runtime ───
# Transport: "http" for Railway / Claude.ai connector, "stdio" for Claude Code local use
TRANSPORT=stdio
PORT=3000
