# Google OAuth2 credentials (token static pattern, same as google-ads-mcp-server)
# Generate refresh_token via https://developers.google.com/oauthplayground
# Scopes required:
#   https://www.googleapis.com/auth/tagmanager.manage.accounts
#   https://www.googleapis.com/auth/tagmanager.edit.containers
#   https://www.googleapis.com/auth/tagmanager.edit.containerversions
#   https://www.googleapis.com/auth/tagmanager.publish
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Transport: "http" for Railway / Claude.ai connector, "stdio" for Claude Code local use
TRANSPORT=stdio
PORT=3000
